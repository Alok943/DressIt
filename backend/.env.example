# Copy to .env and fill in values

# Path to the merged catalog (relative to backend root, or absolute)
CATALOG_PATH=../frontend/public/catalog.json

# Where to append reaction logs
REACTIONS_PATH=reactions.jsonl

# Groq re-ranker (optional — leave blank to skip)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
RERANKER_ENABLED=false

# CORS — add your Vercel domain before deploying
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:5175","http://localhost:5176"]
